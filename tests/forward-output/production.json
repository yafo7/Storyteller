  "story": {
    "facts": [
      {
        "id": "fact.last-train-testimony",
        "text": "Mara says the last train left twenty years ago.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.opening",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 7, "endLine": 7, "confidence": 1 }
        ]
      },
      {
        "id": "fact.elias-brings-suitcase",
        "text": "Elias enters carrying a sealed red suitcase.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.arrival",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 9, "endLine": 9, "confidence": 1 }
        ]
      },
      {
        "id": "fact.mara-hides-key",
        "text": "Mara keeps the departure key hidden in her glove.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.return",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 13, "endLine": 13, "confidence": 1 }
        ]
      },
      {
        "id": "fact.mara-suspects-elias",
        "text": "Mara believes Elias caused the old station fire, although she has never seen proof.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.return",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 13, "endLine": 13, "confidence": 1 }
        ]
      },
      {
        "id": "fact.timetable-names-mara",
        "text": "At midnight the timetable flips by itself and displays Mara's name.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.midnight",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 15, "endLine": 15, "confidence": 1 }
        ]
      },
      {
        "id": "fact.suitcase-was-fathers",
        "text": "Elias says Mara's father pulled him from the fire and the suitcase belonged to her father.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.return",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 17, "endLine": 17, "confidence": 1 }
        ]
      },
      {
        "id": "fact.fire-was-accident",
        "text": "The letter in the suitcase proves the station fire was an accident.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.open-suitcase",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 19, "endLine": 19, "confidence": 1 }
        ]
      },
      {
        "id": "fact.badge-in-suitcase",
        "text": "Mara's father's conductor badge is inside the suitcase.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.open-suitcase",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 19, "endLine": 19, "confidence": 1 }
        ]
      },
      {
        "id": "fact.door-unlocks",
        "text": "The departure door unlocks after the suitcase is opened.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.door-unlocks",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 19, "endLine": 21, "confidence": 1 }
        ]
      },
      {
        "id": "fact.choice-remains-open",
        "text": "Mara may leave or remain to keep the lamp lit for the next lost passenger.",
        "immutable": true,
        "required": true,
        "earliestReveal": "beat.door-unlocks",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 21, "endLine": 21, "confidence": 1 }
        ]
      },
      {
        "id": "fact.mara-leaves",
        "text": "Mara chooses to leave through the departure door.",
        "immutable": false,
        "required": false,
        "earliestReveal": "beat.ending-leave",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 21, "endLine": 21, "confidence": 1 }
        ]
      },
      {
        "id": "fact.mara-stays",
        "text": "Mara chooses to remain and keep the lamp lit.",
        "immutable": false,
        "required": false,
        "earliestReveal": "beat.ending-stay",
        "sourceRefs": [
          { "sourceId": "source.main", "startLine": 21, "endLine": 21, "confidence": 1 }
        ]
      }
