        },
        {
          "parameterId": "parameter.state-axis.transition",
          "valueType": "verb-ref",
          "bindFrom": "designer-decision",
          "sourcePath": "$.stateAxisDesign.transitionVerb",
          "required": true,
          "constraints": [
