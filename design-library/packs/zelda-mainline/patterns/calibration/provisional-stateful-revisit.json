          "parameterId": "parameter.state-axis.route-set",
          "valueType": "route-ref-array",
          "bindFrom": "product-profile",
          "sourcePath": "$.routeGraph.edges[*]",
          "required": true,
          "constraints": [
            "Includes an opened and a closed or altered edge"
