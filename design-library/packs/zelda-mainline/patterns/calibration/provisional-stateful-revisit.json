      "Priority 85: Select as core when the state axis causally changes route reachability; comparison alone is a specialization.",
      "Evaluate before pattern.parallel-state-comparison."
    ],
    "maxCoSelections": 2,
    "storySignals": [
      {
        "ruleId": "rule.state-axis-rewrites-routes.story.1",
        "sourcePath": "$.storyModel.storySignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.parallel-state"
      },
      {
        "ruleId": "rule.state-axis-rewrites-routes.story.2",
        "sourcePath": "$.storyModel.storySignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.transformable-environment"
      },
      {
        "ruleId": "rule.state-axis-rewrites-routes.story.3",
        "sourcePath": "$.storyModel.storySignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.revisited-place"
      }
    ],
    "spatialSignals": [
      {
        "ruleId": "rule.state-axis-rewrites-routes.spatial.1",
        "sourcePath": "$.storyModel.spatialSignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.parallel-state"
      },
      {
        "ruleId": "rule.state-axis-rewrites-routes.spatial.2",
        "sourcePath": "$.storyModel.spatialSignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.transformable-environment"
      },
      {
        "ruleId": "rule.state-axis-rewrites-routes.spatial.3",
        "sourcePath": "$.storyModel.spatialSignals",
        "operator": "contains",
        "valueType": "string",
        "expected": "signal.revisited-place"
      }
    ],
    "prerequisites": [
      "$.storyModel.storySignals must satisfy contains \"signal.parallel-state\".",
      "$.storyModel.storySignals must satisfy contains \"signal.transformable-environment\".",
      "$.designEvidence.stateAxes[*].routeDeltaCount must satisfy greater-or-equal 2."
    ],
    "contraindications": [
      "The two states are unrelated replacement maps",
      "One state only reskins the other",
      "The transition can irreversibly close every required route",
      "$.designEvidence.stateAxes[*].transitionDomain equals \"continuous-heading\"",
      "$.productProfile.spatialPromise equals \"unconstrained-open-navigation\""
    ],
    "abstainWhen": [
      "The two states are unrelated replacement maps",
      "One state only reskins the other",
      "The transition can irreversibly close every required route"
    ]
  },
  "effectPrimitives": [
    {
      "effectId": "effect.state-axis.apply-value",
      "kind": "toggle-map-layer",
      "preconditions": [
        "$.world.stateAxis.transitionAllowed must satisfy equals against true before the authored transaction is accepted.",
        "$.player.currentVerb must satisfy equals-ref against reference parameter.state-axis.transition before the authored transaction is accepted."
      ],
      "parameters": [
        "parameter.state-axis.axis",
        "parameter.state-axis.location",
        "parameter.state-axis.transition"
      ],
      "postconditions": [
        "$.world.locations[location].activeAxisValue must satisfy equals against \"requested-value\" before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract.",
        "$.world.locations[location].visualCollisionInteractionVersion must satisfy internally-consistent against true before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract."
      ],
      "observableFeedback": [
        "visual",
        "audio"
      ],
      "rollback": "reversible"
    },
    {
      "effectId": "effect.state-axis.recompute-routes",
      "kind": "unlock-route",
      "preconditions": [
        "$.world.stateAxis.activeValue must satisfy equals against \"requested-value\" before the authored transaction is accepted."
      ],
      "parameters": [
        "parameter.state-axis.axis",
        "parameter.state-axis.route-set"
      ],
      "postconditions": [
        "$.navigation.routeSet must satisfy matches-axis-table against true before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract.",
        "$.navigation.requiredEscape must satisfy reachable against true before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract."
      ],
      "observableFeedback": [
        "navigation"
      ],
      "rollback": "reversible"
    },
    {
      "effectId": "effect.state-axis.close-tradeoff-routes",
      "kind": "lock-route",
      "preconditions": [
        "$.navigation.routeSet.hasTradeoff must satisfy equals against true before the authored transaction is accepted."
      ],
      "parameters": [
        "parameter.state-axis.axis",
        "parameter.state-axis.route-set"
      ],
      "postconditions": [
        "$.navigation.closedEdges must satisfy equals against \"axis-declared-closed-edges\" before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract.",
        "$.navigation.requiredGoal must satisfy reachable against true before the authored transaction is accepted. This realizes the distinct discrete-route-axis causal contract."
      ],
      "observableFeedback": [
        "animation",
        "ui"
      ],
      "rollback": "reversible"
    }
  ],
