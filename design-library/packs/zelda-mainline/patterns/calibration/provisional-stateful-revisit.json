    "score": {
      "criteria": [
        {
          "criterionId": "criterion.state-axis.consequence-consistency",
          "weight": 0.35,
          "evidencePath": "$.designEvidence.stateAxes[*].entityRuleCoverage",
          "rule": "Reward the same axis value producing consistent consequences across terrain, blockers, and actors."
        },
        {
          "criterionId": "criterion.state-axis.route-balance",
          "weight": 0.25,
          "evidencePath": "$.productProfile.routeGraphDeltas[*].openedAndClosedEdges",
          "rule": "Reward meaningful tradeoffs rather than a universally better state."
        },
        {
          "criterionId": "criterion.state-axis.legibility",
          "weight": 0.2,
          "evidencePath": "$.performancePlan.stateFeedbackChannels",
          "rule": "Require at least two non-color channels that identify the active state."
        },
        {
          "criterionId": "criterion.state-axis.recovery",
          "weight": 0.2,
          "evidencePath": "$.acceptance.routeMatrix.resetAndEscape",
          "rule": "Require a reachable state-change or escape action from every required zone."
        }
      ],
      "hardVetoes": [
        "The two states are unrelated replacement maps",
        "One state only reskins the other",
        "The transition can irreversibly close every required route"
      ]
    },
