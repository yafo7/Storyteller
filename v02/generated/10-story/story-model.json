  "dramaticPromise": "你必须用门与黑暗保护孩子，却会逐渐发现每一次保护都在遮蔽另一个世界。",
  "dramaticSpine": [
    "Grace 以严格的门窗规则维持家庭安全。",
    "未寄出的招聘信和熟悉宅邸的仆人制造第一处矛盾。",
    "Anne 看见 Victor，活人与死者的房间开始重叠。",
    "Charles 从雾中短暂归来，Grace 的记忆出现裂缝。",
    "窗帘消失、墓碑出现，保护规则失效。",
    "降灵会揭示 Grace 一家才是无法离开的死者。",
    "Grace 接受未知，并重新定义家与光。"
  ],
  "playerRole": {
    "characterId": "character.grace",
    "immediateNeed": "在强光出现前关闭育儿室百叶窗并安全地找到孩子。",
    "initialBeliefs": ["孩子接触强光会死亡", "家里只有家人与新来的仆人", "门窗规则可以维持安全"],
    "knowledgeLimits": ["不知道自己与孩子已经死亡", "不知道 Victor 一家是活人", "不记得自己杀死孩子后自杀"],
    "availableVerbs": ["移动", "开关门窗", "查看", "拿取", "使用", "交谈", "聆听", "放置证物"],
    "selectionReason": "她既能支配宅邸，也被自身信念限制；玩家的操作可直接表达控制与失控。"
  },
  "facts": [
    {"id": "fact.door-rule", "text": "打开下一扇门前必须关闭上一扇门。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 106, "endLine": 122}]},
    {"id": "fact.children-light", "text": "Grace 坚信孩子对强光致命过敏。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 205, "endLine": 220}]},
    {"id": "fact.letter-unposted", "text": "招聘信五天前仍在信箱中，仆人却主动到来。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 262, "endLine": 284}]},
    {"id": "fact.servants-knew-house", "text": "Mills、Tuttle 与 Lydia 很久以前在宅邸工作。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 288, "endLine": 314}]},
    {"id": "fact.victor-seen", "text": "Anne 看见名为 Victor 的男孩和参观房子的家人。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 529, "endLine": 592}]},
    {"id": "fact.worlds-overlap", "text": "活人与死者的世界会彼此重叠。", "immutable": true, "confidence": 0.98, "sourceRefs": [{"sourceId": "source.main", "startLine": 1119, "endLine": 1154}]},
    {"id": "fact.charles-dead", "text": "Charles 已死于战争，只短暂回家告别。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 1219, "endLine": 1258}, {"sourceId": "source.main", "startLine": 1517, "endLine": 1554}]},
    {"id": "fact.curtains-removed", "text": "宅邸全部窗帘被活人取下，日光涌入。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 1556, "endLine": 1619}]},
    {"id": "fact.servants-dead", "text": "三名仆人半个多世纪前死于肺结核。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 1702, "endLine": 1750}]},
    {"id": "fact.family-dead", "text": "Grace 闷死孩子后开枪自杀，一家人仍留在宅邸。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 1892, "endLine": 1947}]},
    {"id": "fact.light-safe-now", "text": "结局中阳光不再伤害孩子。", "immutable": true, "confidence": 1, "sourceRefs": [{"sourceId": "source.main", "startLine": 1984, "endLine": 1987}]}
  ],
