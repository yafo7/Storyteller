    {"id":"fact.family-dead","text":"Grace 闷死孩子后开枪自杀，一家人仍留在宅邸。","immutable":true,"confidence":1,"sourceRefs":[{"sourceId":"source.main","startLine":1892,"endLine":1947}]},
