  "objectives": [
    {
      "stage": 0,
      "text": "合上育儿室的百叶窗帘，保护孩子。",
      "hint": "走到北侧漏光的窗前，面朝窗帘按 E。"
    },
    {
      "stage": 1,
      "text": "去走廊门厅检查今天的信件。",
      "hint": "南侧房门已打开。门链一次只允许一扇门开启。"
    },
    {
      "stage": 2,
      "text": "回育儿室，查明 Anne 所说的 Victor。",
      "hint": "从门厅西侧原路返回；观察另一扇自行颤动的窗帘。"
    },
    {
      "stage": 3,
      "text": "去音乐室，循哭声调谐重叠的房间。",
      "hint": "走廊东门已经出现紫色边光。"
    },
    {
      "stage": 4,
      "text": "在重叠层取走死者肖像册。",
      "hint": "钢琴北侧的柜子刚刚显现。"
    },
    {
      "stage": 5,
      "text": "沿新出现的花园路，拓印三块墓碑。",
      "hint": "大厅南门被晨光照亮；三座墓碑都要查看。"
    },
    {
      "stage": 6,
      "text": "前往北侧降灵室，把三件证物放上圆桌。",
      "hint": "每次按 E 放下一件证物，世界会更加重叠。"
    },
    {
      "stage": 7,
      "text": "回到育儿室，与孩子一起拉开最后的窗帘。",
      "hint": "走入北侧金色光斑，亲手接受晨光。"
    },
    {
      "stage": 8,
      "text": "故事已经结束。你仍可探索改变后的宅邸。",
      "hint": "按 Esc 打开菜单，可从降灵会检查点重播结局。"
    }
  ],
