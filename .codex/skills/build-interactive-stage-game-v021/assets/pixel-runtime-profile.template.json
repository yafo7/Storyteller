{
  "$schema": "script-game-pixel-runtime-profile/v1",
  "schemaVersion": "1.0.0",
  "rendererProfile": {
    "mode": "top-down-tilemap",
    "logicalResolution": [320, 180],
    "tileSize": 16,
    "movement": "four-direction",
    "interaction": "facing-tile",
    "sampling": "nearest-neighbor",
    "cameraSnap": "integer-pixel"
  },
  "requiredCapabilities": [
    "tile-layers",
    "animated-tiles",
    "sprite-sheets",
    "collision",
    "portals",
    "triggers",
    "overhead-occlusion",
    "npc-tile-routes",
    "world-state-deltas",
    "dialogue",
    "inventory",
    "save-resume",
    "deterministic-cutscene-fallbacks"
  ]
}
