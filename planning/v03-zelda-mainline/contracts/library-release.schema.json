{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyteller.local/schemas/v03/library-release.schema.json",
  "title": "V0.3 complete design-library release draft",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "libraryId", "libraryVersion", "status", "hashPolicy", "schemaVersions", "packs", "core", "indexes", "migrations", "qualityEvidence", "fileManifest"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "libraryId": { "type": "string", "pattern": "^library\\." },
    "libraryVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "enum": ["alpha", "beta", "release-candidate", "stable", "deprecated"] },
    "hashPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "canonicalizationVersion", "treeHash"],
      "properties": {
        "algorithm": { "const": "canonical-tree-sha256/v1" },
        "canonicalizationVersion": { "const": "1" },
        "treeHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "schemaVersions": { "type": "object", "minProperties": 12, "additionalProperties": { "type": "string" } },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packId", "version", "manifestHash"],
        "properties": {
          "packId": { "type": "string", "pattern": "^pack\\." },
          "version": { "type": "string" },
          "manifestHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patternRefs", "adapterRefs", "compositionRuleRefs", "provenanceIndexHash"],
      "properties": {
        "patternRefs": { "type": "array", "items": { "type": "string", "pattern": "^pattern\\." }, "uniqueItems": true },
        "adapterRefs": { "type": "array", "items": { "type": "string", "pattern": "^adapter\\." }, "minItems": 1, "uniqueItems": true },
        "compositionRuleRefs": { "type": "array", "items": { "type": "string" } },
        "provenanceIndexHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "indexes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["indexId", "version", "hash"],
        "properties": {
          "indexId": { "type": "string", "minLength": 1 },
          "version": { "type": "string" },
          "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "migrations": { "type": "array", "items": { "type": "string", "pattern": "^migration\\." }, "uniqueItems": true },
    "qualityEvidence": { "type": "array", "items": { "type": "string", "pattern": "^G([0-9]|1[0-4])$" }, "minItems": 1, "uniqueItems": true },
    "fileManifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "stable" } }, "required": ["status"] },
      "then": {
        "properties": {
          "qualityEvidence": {
            "contains": { "const": "G13" },
            "minContains": 1,
            "minItems": 15,
            "maxItems": 15
          }
        }
      }
    }
  ]
}
