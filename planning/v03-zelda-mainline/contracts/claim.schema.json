{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyteller.local/schemas/v03/claim.schema.json",
  "title": "V0.3 research claim ledger record draft",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "claimId", "claimType", "criticality", "minimumSourceTier", "statement", "workRefs", "evidence", "confidence", "status", "review"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "claimId": { "type": "string", "pattern": "^claim\\.[a-z0-9.-]+$" },
    "claimType": { "enum": ["fact", "interpretation", "comparison", "lineage", "analogy"] },
    "criticality": { "enum": ["critical", "supporting", "context"] },
    "minimumSourceTier": { "enum": ["A", "B", "C", "D"] },
    "statement": { "type": "string", "minLength": 20 },
    "workRefs": { "type": "array", "items": { "type": "string", "pattern": "^work\\." }, "minItems": 1, "uniqueItems": true },
    "versionRefs": { "type": "array", "items": { "type": "string", "pattern": "^version\\." }, "uniqueItems": true },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceRef", "locator", "relation"],
        "properties": {
          "sourceRef": { "type": "string", "pattern": "^source\\." },
          "locator": { "type": "string", "minLength": 3 },
          "relation": { "enum": ["supports", "contradicts", "contextualizes"] }
        }
      }
    },
    "confidence": { "enum": ["low", "medium", "high"] },
    "status": { "enum": ["draft", "reviewed", "verified", "contested", "superseded"] },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "reviewer", "notes"],
      "properties": {
        "author": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string", "minLength": 1 },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "criticality": { "const": "critical" } }, "required": ["criticality"] },
      "then": { "properties": { "minimumSourceTier": { "enum": ["A", "B"] } } }
    }
  ]
}
