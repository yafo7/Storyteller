{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyteller.local/schemas/v03/benchmark-case.schema.json",
  "title": "V0.3 selector benchmark case draft",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "benchmarkId", "category", "inputFixture", "productProfile", "runtimeCapabilities", "expectedProperties", "forbiddenProperties", "abstentionExpectation", "seeds", "metrics", "status"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "benchmarkId": { "type": "string", "pattern": "^benchmark\\." },
    "category": { "enum": ["locked-room", "relationship-drama", "journey-chase", "open-exploration", "comedy", "dialogue-heavy", "low-spatial-change", "negative-control", "regression"] },
    "inputFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "hash", "originalityStatement"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "originalityStatement": { "type": "string", "minLength": 20 }
      }
    },
    "productProfile": { "type": "string", "minLength": 1 },
    "runtimeCapabilities": { "type": "array", "items": { "type": "string", "pattern": "^capability\\." } },
    "expectedProperties": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "forbiddenProperties": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "abstentionExpectation": { "enum": ["must-select", "may-abstain", "must-abstain"] },
    "seeds": { "type": "array", "items": { "type": "integer" }, "minItems": 3, "uniqueItems": true },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metricId", "comparator", "threshold", "unit", "hardGate"],
        "properties": {
          "metricId": { "type": "string", "pattern": "^metric\\." },
          "comparator": { "enum": ["greater-than", "greater-or-equal", "less-than", "less-or-equal", "equals"] },
          "threshold": { "type": "number" },
          "unit": { "type": "string", "minLength": 1 },
          "hardGate": { "type": "boolean" }
        }
      }
    },
    "status": { "enum": ["draft", "calibrated", "active", "retired"] },
    "failureOwner": { "type": "string" }
  }
}
